<?xml version="1.0"?>
<ruleset name="Ziggy">
    <description>PSR-12 coding standard for Ziggy project</description>

    <file>src</file>
    <file>tests</file>

    <arg name="colors"/>
    <arg value="p"/>

    <rule ref="PSR12"/>

    <exclude-pattern>src/DataFixtures/</exclude-pattern>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>
</ruleset>
