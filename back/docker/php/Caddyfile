{
    frankenphp
    auto_https off
}

:{$PORT:80} {
    root * /app/public
    encode zstd br gzip

    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 3
        }
        format json
    }

    # API routes → Symfony PHP
    handle /api/* {
        php_server {
            resolve_root_symlink
        }
    }

    # All other routes → Vue SPA (try static file, fallback to index.html)
    handle {
        try_files {path} /build/index.html
        file_server
    }
}
