# ══════════════════════════════════════════════════════════════════════════════
# Ziggy — Production Environment Variables
# Copy this file to .env.prod and fill in all values.
# NEVER commit .env.prod to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Docker image ──────────────────────────────────────────────────────────────
# GitHub repository in lowercase (owner/repo)
GITHUB_REPOSITORY=your-org/ziggy-v2
# Tag to deploy — set by CI, or use "latest" for manual deploys
IMAGE_TAG=latest

# ── Application ───────────────────────────────────────────────────────────────
# Your public domain name (e.g. app.yourdomain.com)
SERVER_NAME=app.yourdomain.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=ops@yourdomain.com

# 64-character random hex string — generate with:
#   openssl rand -hex 32
APP_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# URL of the frontend for use in email links, etc.
FRONTEND_BASE_URL=https://app.yourdomain.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Regex matching allowed origins (adjust to your real domain)
CORS_ALLOW_ORIGIN='^https://app\.yourdomain\.com$'

# ── JWT ──────────────────────────────────────────────────────────────────────
# Passphrase used to encrypt the RSA private key
# Generate with: openssl rand -hex 32
JWT_PASSPHRASE=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_DB=ziggy
POSTGRES_USER=ziggy
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Mailer ───────────────────────────────────────────────────────────────────
# Examples:
#   SMTP with auth:        smtp://user:pass@smtp.yourdomain.com:587
#   Infomaniak mail:       smtp://user%40domain.com:password@mail.infomaniak.com:587
#   Mailgun:               mailgun+api://KEY:DOMAIN@default
#   Disable (no emails):   null://null
MAILER_DSN=smtp://user:password@smtp.yourdomain.com:587
